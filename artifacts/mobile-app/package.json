{
  "name": "edumetrics",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 8082",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:apk": "EXPO_TOKEN=$EXPO_TOKEN ./node_modules/.bin/eas build --platform android --profile preview --non-interactive",
