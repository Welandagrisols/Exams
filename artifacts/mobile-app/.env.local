# API server URL for Expo dev builds on Replit.
# The API server runs on port 8080.  When testing via Expo Go on a device,
# replace this with your Replit dev-domain URL, e.g.:
#   EXPO_PUBLIC_API_URL=https://<your-replit-dev-domain>:8080
# For local LAN testing (USB-forwarded or emulator) keep as:
#   EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_API_URL=http://localhost:8080
