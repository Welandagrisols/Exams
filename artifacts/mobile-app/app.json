{
  "expo": {
    "name": "EduMetrics",
    "slug": "jss-exam-analyser",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "edumetrics",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jss.examanalyser"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1e3a5f"
      },
      "package": "com.jss.examanalyser"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1e3a5f",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "backgroundColor": "#1e3a5f"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cdf2b7dc-1f54-47ae-b932-047cba437d97"
      }
    },
    "owner": "agrisols2025"
  }
}
